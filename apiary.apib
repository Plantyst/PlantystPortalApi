                  "description": null,
                  "operations": null,
                  "targetAmount": null,
                  "customFields": null,
                  "_links": [
                    {
                      "rel": "self",
                      "href": "~/Api/JobTypes/42457026",
                      "title": null,
                      "isTemplated": false
                    }
                  ],
                  "_embedded": null
                },
                {
                  "jobTypeId": 41205284,
                  "title": "01.SP",
                  "setpoint": 36.67,
                  "measurementId": 1771,
                  "plannedFrom": null,
                  "plannedTo": null,
                  "isPermanent": false,
                  "currentState": "Available",
                  "maximumProductionCoefficient": null,
                  "order": 1,
                  "commandGuid": "1d8a6a09-d957-4969-9c69-2a061d6c92f4",
                  "description": null,
                  "operations": null,
                  "targetAmount": null,
                  "customFields": null,
